{
  "name": "krafty",
  "private": true,
  "description": "Krafty is HTML Checker for Web Director",
  "license": "MIT",
  "scripts": {
    "build": "sass --no-source-map --style=compressed code/content.scss code/content.css",
    "watch": "sass --no-source-map --style=compressed --watch code/content.scss code/content.css",
    "package": "npm run build && node scripts/package.js"
  },
  "devDependencies": {
    "sass": "^1.101.0"
  }
}
